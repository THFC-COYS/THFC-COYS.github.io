# Copy this to .env and fill in your values
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Credential encryption key (choose any strong passphrase)
CAREER_ENGINE_KEY=choose_a_strong_passphrase_here

# Auto-submit threshold (0.0-1.0). Jobs scoring above this AND passing 96% ATS are auto-submitted.
AUTO_SUBMIT_THRESHOLD=0.85

# Browser automation settings
BROWSER_HEADLESS=true   # Set to false to watch the browser fill forms

# Server config
HOST=0.0.0.0
PORT=8000
FRONTEND_ORIGIN=http://localhost:3000

# ── Credential setup (run once after install) ────────────────────────────────
# Store your login credentials securely (encrypted at rest):
#   python credentials.py save linkedin your@email.com yourpassword
#   python credentials.py save personal_info your@email.com "4803327866"
#
# personal_info fields used across all platforms:
#   python credentials.py save personal_info greg.lucas1@icloud.com 4803327866
# (The script also reads first_name, last_name, city, state, zip, linkedin, portfolio
#  — edit credentials.py to add these as a JSON object if needed)
#
# After saving personal_info, install browser automation deps:
#   playwright install chromium
